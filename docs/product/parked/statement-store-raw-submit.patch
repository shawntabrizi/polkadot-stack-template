+function makeExpiry(): bigint {
+	// Upper 32 bits: absolute expiration (unix seconds, ~1 year out).
+	// Lower 32 bits: sequence number (best-effort unique per-process).
+	const expSec = BigInt(Math.floor(Date.now() / 1000) + 31_536_000);
+	const seq = BigInt(Date.now() & 0xffffffff);
+	return (expSec << 32n) | seq;
+}
