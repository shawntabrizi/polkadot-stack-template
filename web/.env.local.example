# Demo accounts for Paseo testnet — copy to .env.local and fill in your private keys.
# Generate fresh keys: node -e "const {generatePrivateKey,privateKeyToAccount}=require('viem/accounts'); const pk=generatePrivateKey(); console.log(pk, privateKeyToAccount(pk).address)"
# Fund the H160 addresses at https://faucet.polkadot.io (select Paseo Asset Hub).
# Import each account into Polkadot.js extension using the mnemonic (type: Ethereum).
#
# Account 0 — Council signer 1 (proposes addMedic multisig)
VITE_ACCOUNT_0_PK=0x
VITE_ACCOUNT_0_NAME=Council-1

# Account 1 — Council signer 2 (approves addMedic multisig, threshold reached)
VITE_ACCOUNT_1_PK=0x
VITE_ACCOUNT_1_NAME=Council-2

# Account 2 — Medic / Patient (signs records on MedicSign, lists them on PatientDashboard)
VITE_ACCOUNT_2_PK=0x
VITE_ACCOUNT_2_NAME=Medic
