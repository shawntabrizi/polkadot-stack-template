
# The app falls back to local endpoints on localhost and testnet endpoints elsewhere.
# Set these if you want explicit build-time defaults or script-driven local overrides.

# Preferred for local script-driven development:
# VITE_LOCAL_WS_URL=ws://127.0.0.1:10044
# VITE_LOCAL_ETH_RPC_URL=http://127.0.0.1:8645

VITE_LOCAL_WS_URL=ws://127.0.0.1:9944
VITE_LOCAL_ETH_RPC_URL=http://127.0.0.1:8545

VITE_WS_URL=ws://127.0.0.1:9944
VITE_ETH_RPC_URL=http://127.0.0.1:8545

# Example Polkadot Hub TestNet defaults:
# VITE_WS_URL=wss://services.polkadothub-rpc.com/testnet
# VITE_ETH_RPC_URL=https://services.polkadothub-rpc.com/testnet

# Hybrid demo: contracts on Paseo, Statement Store on a local node.
# When set, overrides the default Statement Store routing (local-for-local,
# Paseo-People-for-testnet) — every statement_submit / statement_dump call
# goes to this URL regardless of the main wsUrl. Leave unset for normal use.
# VITE_STATEMENT_STORE_WS_URL=ws://127.0.0.1:9944
